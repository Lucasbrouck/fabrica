# Configurações do Banco de Dados
DATABASE_URL="postgresql://usuario:senha@localhost:5432/nome_do_banco"

# Autenticação
JWT_SECRET="sua-chave-secreta-segura"

# Integração Asaas
ASAAS_API_KEY="sua_chave_api_asaas"
ASAAS_WEBHOOK_TOKEN="seu_token_webhook_asaas"

# === INTEGRAÇÃO GOOGLE SHEETS ===
# ID da planilha (longo hash na URL)
GOOGLE_SPREADSHEET_ID="seu_id_da_planilha"

# Nome exato da Aba/Guia na planilha
GOOGLE_SHEET_TAB_NAME="Cobranças"

# E-mail da Conta de Serviço (Service Account)
GOOGLE_CLIENT_EMAIL="seu-app@projeto.iam.gserviceaccount.com"

# Chave Privada (Private Key) - Mantenha as aspas duplas!
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"
